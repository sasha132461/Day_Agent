# Local: leave NEXT_PUBLIC_API_URL unset so /api/* is rewritten to the backend.
# NEXT_PUBLIC_API_URL=

# Backend URL for Next.js rewrites (local / LAN)
BACKEND_URL=http://127.0.0.1:8000

# Hosted: browser calls API directly (HTTPS); avoids long-request limits on the host proxy.
# NEXT_PUBLIC_API_URL=https://api.example.com
